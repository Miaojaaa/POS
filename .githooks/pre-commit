#!/usr/bin/env sh
# Salon POS pre-commit hook.
# Blocks commits that would push stale settings to teammates.
# Bypass once with: git commit --no-verify

repo_root="$(git rev-parse --show-toplevel)"
checker="$repo_root/salon-pos/scripts/check-config-sync.js"

if [ ! -f "$checker" ]; then
  exit 0
fi

if ! command -v node >/dev/null 2>&1; then
  echo "[pre-commit] node not on PATH — skipping config-sync check."
  exit 0
fi

node "$checker"
